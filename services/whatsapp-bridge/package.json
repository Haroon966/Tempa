{
  "name": "tempa-whatsapp-bridge",
  "version": "1.0.0",
  "description": "Tempa in-repo WhatsApp bridge (Baileys, Evolution-compatible API)",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
