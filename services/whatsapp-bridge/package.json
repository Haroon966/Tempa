    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pino": "^9.10.0",
    "prisma": "^6.16.2",
    "qrcode": "^1.5.4",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.18",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.20.5",
    "typescript": "^5.7.2"
  }
