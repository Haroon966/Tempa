GROQ_API_KEY=gsk_your_groq_api_key_here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
TEMPA_DATA_DIR=./data
TEMPA_DAEMON_PORT=8787
# Native daemon + Docker WhatsApp bridge: bind on all interfaces so webhooks reach the daemon
TEMPA_BIND_HOST=0.0.0.0
TEMPA_WEBHOOK_BASE_URL=http://host.docker.internal:8787
TEMPA_CORS_ORIGIN=*
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tempa-evolution-key
# WhatsApp bridge instance name (services/whatsapp-bridge)
TEMPA_INSTANCE_NAME=tempa
# Auto-reply + reminders only to this number; add more in dashboard Connections → WhatsApp
WHATSAPP_OWNER_NUMBER=
# Slack (Socket Mode) — also enable App Home → Messages Tab (see README)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_OWNER_USER_ID=U01234567
# Optional comma-separated Slack user IDs allowed to DM the bot (ignored when SLACK_ALLOW_ALL=true)
SLACK_ALLOWED_USER_IDS=
# When true, any Slack user can use email, calendar, WhatsApp, and meeting tools via DM
SLACK_ALLOW_ALL=false
# IANA timezone for calendar times, WhatsApp replies, and event creation (Pakistan: Asia/Karachi)
TEMPA_TIMEZONE=Asia/Karachi
# QA Agent — GitHub (choose one auth method)
# Option A: Personal Access Token (simplest — manage repos in dashboard QA tab)
GITHUB_TOKEN=
# Optional seed list; dashboard and chat approvals can add more at runtime
GITHUB_REPOS=
# Option B: GitHub App (webhooks, auto-scan on push/PR)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=
TEMPA_QA_ENABLED=true
TEMPA_QA_SCAN_INTERVAL_MINUTES=60
TEMPA_QA_MAX_BRANCHES_PER_REPO=50
TEMPA_QA_DEEP_REVIEW_MODE=lite
# Deep PR review uses Claude; all other QA tasks use Groq
ANTHROPIC_API_KEY=
TEMPA_QA_CLAUDE_MODEL=claude-sonnet-4-20250514
# Coordinator: langgraph | varys | hybrid
TEMPA_COORDINATOR=varys
VARYS_ORCHESTRATOR_ENABLED=true
VARYS_TICK_SECONDS=270
VARYS_HARNESS_DB=./data/harness/harness.db
VARYS_VAULT_DIR=./data/vault
VARYS_AGENT_NAME=Tempa
VARYS_OWNER_NAME=
NOTION_API_KEY=
NOTION_HARNESS_DB_ID=
NOTION_ENABLED=false
# Jira Cloud — API token auth (dashboard Connections or env)
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
JIRA_ENABLED=false
JIRA_DEFAULT_PROJECT=
CLAUDE_CODE_PATH=claude
# When true, Varys never falls back to Anthropic API — Claude Code CLI only
VARYS_CLAUDE_CLI_ONLY=true
