GROQ_API_KEY=gsk_your_groq_api_key_here
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
TEMPA_DATA_DIR=./data
TEMPA_DAEMON_PORT=8787
# Native daemon + Docker Evolution: bind on all interfaces so webhooks reach the daemon
TEMPA_BIND_HOST=0.0.0.0
TEMPA_WEBHOOK_BASE_URL=http://host.docker.internal:8787
TEMPA_CORS_ORIGIN=*
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=tempa-evolution-key
TEMPA_INSTANCE_NAME=tempa
# Auto-reply + reminders only to this number; add more in dashboard Connections → WhatsApp
WHATSAPP_OWNER_NUMBER=
